theory:
  camb:
    extra_args:
      num_massive_neutrinos: 1
likelihood:
  bao.desi_dr2:
    path: null
    measurements_file: C:/EPFL/MA4/code/fake_BAO_data/LCDM/w0=neg1_wa=0_not_random.txt
params:
  logA:
    value: 3.0448
    latex: \log(10^{10} A_\mathrm{s})
  As:
    value: 'lambda logA: 1e-10*np.exp(logA)'
    latex: A_\mathrm{s}
  H0:
    value: 60
    latex: H_0
  hrdrag:
    prior:
      min: 30
      max: 300
    ref:
      dist: norm
      loc: 100
      scale: 1
    proposal: 0.5
    latex: hr_\mathrm{d}
  rdrag:
    value: 'lambda hrdrag, H0: 100 * hrdrag / H0'
    latex: r_\mathrm{d}
  omch2:
    prior:
      min: 0.001
      max: 0.99
    ref:
      dist: norm
      loc: 0.12
      scale: 0.001
    proposal: 0.0001
    latex: \Omega_\mathrm{c} h^2
  mnu:
    latex: \sum m_\nu
    value: 0.06
  nnu:
    latex: N_\mathrm{eff}
    value: 3.044
  omegam:
    latex: \Omega_\mathrm{m}
  omegamh2:
    derived: 'lambda omegam, H0: omegam*(H0/100)**2'
    latex: \Omega_\mathrm{m} h^2
  omega_de:
    latex: \Omega_\Lambda
  YHe:
    latex: Y_\mathrm{P}
  Y_p:
    latex: Y_P^\mathrm{BBN}
  DHBBN:
    derived: 'lambda DH: 10**5*DH'
    latex: 10^5 \mathrm{D}/\mathrm{H}
  tau:
    value: 0.054
    latex: \tau_\mathrm{reio}
  zrei:
    latex: z_\mathrm{re}
sampler:
  mcmc:
    covmat: auto
    Rminus1_stop: 0.01
output: cobaya_test_runs/base_LCDM/LCDM_fakedata_not_random_H060
